[node name="DayLabel" type="Label" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
text = "Day 1 / 7"

[node name="ClockLabel" type="Label" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
text = "Daylight 5:00"

[node name="TowerLabel" type="Label" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
text = "Tower 100/100"

[node name="FoesLabel" type="Label" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
visible = false
text = "Foes: 0"

[node name="LeftSpacer" type="Control" parent="TopBar/Margin/Row"]
size_flags_horizontal = 3

[node name="MaterialsRow" type="HBoxContainer" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
theme_override_constants/separation = 16

[node name="RightSpacer" type="Control" parent="TopBar/Margin/Row"]
size_flags_horizontal = 3

[node name="PlayersLabel" type="Label" parent="TopBar/Margin/Row"]
unique_name_in_owner = true
text = "Players: 1"

[node name="ConnectingPanel" type="ColorRect" parent="."]
unique_name_in_owner = true
visible = false
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.04, 0.05, 0.1, 0.88)

[node name="ConnectingLabel" type="Label" parent="ConnectingPanel"]
