[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/building/build_menu.gd" id="1_script"]

[node name="BuildMenu" type="CanvasLayer"]
script = ExtResource("1_script")

[node name="BottomBar" type="PanelContainer" parent="."]
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -92.0
grow_horizontal = 2
grow_vertical = 0

[node name="Margin" type="MarginContainer" parent="BottomBar"]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 6

[node name="Rows" type="VBoxContainer" parent="BottomBar/Margin"]
theme_override_constants/separation = 4

[node name="Hint" type="Label" parent="BottomBar/Margin/Rows"]
modulate = Color(1, 1, 1, 0.65)
horizontal_alignment = 1
theme_override_font_sizes/font_size = 11
text = "1-3 select  |  Left-click place  |  Right-click cancel  |  X removes under cursor (wall = full refund, tower = 50%)"

[node name="Slots" type="HBoxContainer" parent="BottomBar/Margin/Rows"]
unique_name_in_owner = true
alignment = 1
theme_override_constants/separation = 12
